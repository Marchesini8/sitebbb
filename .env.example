# Railway define PORT automaticamente em produção.
# Para rodar localmente, descomente a linha abaixo se quiser fixar a porta.
# PORT=3000

# Pagamentos IronPay
PAYMENT_API_URL=https://api.ironpayapp.com.br/api/public/v1
PAYMENT_API_KEY=
PAYMENT_PIX_ENDPOINT=/transactions
IRONPAY_OFFER_HASH=
IRONPAY_PRODUCT_HASH=
IRONPAY_POSTBACK_URL=https://seu-app.up.railway.app/api/webhooks/ironpay
IRONPAY_EXPIRE_IN_DAYS=1
IRONPAY_WEBHOOK_SECRET=

# Dados padrão usados caso algum campo não venha do formulário.
DEFAULT_PHONE_NUMBER=21999999999
DEFAULT_STATE=RJ
DEFAULT_NEIGHBORHOOD=Centro

# Use true apenas para testar sem chamar a API real.
ALLOW_MOCK_PIX=false
